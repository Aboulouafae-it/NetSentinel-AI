# NetSentinel AI production-style appliance configuration
ENVIRONMENT=production
DEBUG=false
APP_VERSION=1.0.0
EDITION=appliance
BUILD_DATE=
GIT_COMMIT=

# Generate with: openssl rand -hex 48
SECRET_KEY=change-me-with-a-long-random-secret

POSTGRES_USER=netsentinel
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=netsentinel
DATABASE_URL=postgresql+asyncpg://netsentinel:change-me-postgres-password@postgres:5432/netsentinel

REDIS_URL=redis://redis:6379/0

# Comma-separated list parsed by pydantic-settings for deployment environments.
CORS_ORIGINS=["https://netsentinel.local"]
NEXT_PUBLIC_API_URL=https://netsentinel.local/api/v1

# Do not use static development agent tokens in production.
EDGE_AGENT_TOKENS=

BACKUP_DIR=/opt/netsentinel/backups
REPORTS_DIR=/opt/netsentinel/reports
APPLIANCE_LOG_DIR=/var/log/netsentinel
APPLIANCE_DATA_DIR=/var/lib/netsentinel
NETSENTINEL_COMPOSE_FILE=/opt/netsentinel/docker-compose.prod.yml
