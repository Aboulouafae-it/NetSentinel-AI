# =============================================================================
# NetSentinel AI — Environment Configuration
# Copy this file to .env and adjust values for your environment
# =============================================================================

# --- Database ---
POSTGRES_USER=netsentinel
POSTGRES_PASSWORD=netsentinel_dev_password
POSTGRES_DB=netsentinel
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://netsentinel:netsentinel_dev_password@postgres:5432/netsentinel

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=dev-secret-key-change-in-production-immediately
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# --- Environment ---
ENVIRONMENT=development
DEBUG=true
